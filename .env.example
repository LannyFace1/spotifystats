# ============================================================
# MySpotify - Environment Variables
# ============================================================
# Copy to .env and fill in your values
# NEVER commit .env to version control

# --- Spotify Application ---
# Create your app at: https://developer.spotify.com/dashboard
SPOTIFY_PUBLIC=your_spotify_client_id_here
SPOTIFY_SECRET=your_spotify_client_secret_here

# --- URLs ---
# The URL where your SERVER is accessible (for Spotify OAuth callback)
# Must be added in your Spotify App's Redirect URIs as:
#   http://YOUR_DOMAIN/api/auth/spotify/callback
API_ENDPOINT=http://localhost:3000

# The URL where your CLIENT is accessible (for redirects after login)
CLIENT_ENDPOINT=http://localhost:3000

# --- Security ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_secure_random_string_at_least_64_chars

# --- CORS ---
# Comma-separated list of allowed origins
CORS=http://localhost:3000

# --- App ---
# Port for the nginx proxy (default: 3000)
PORT=3000

# Log level: error, warn, info, debug
LOG_LEVEL=info

# --- Optional ---
# Max import cache size (leave empty for unlimited)
# MAX_IMPORT_CACHE_SIZE=500
